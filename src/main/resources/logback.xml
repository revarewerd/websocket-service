<?xml version="1.0" encoding="UTF-8"?>
<!--
  WEBSOCKET SERVICE — КОНФИГУРАЦИЯ ЛОГИРОВАНИЯ
  Текстовый формат для dev, JSON для production (Grafana/Loki)
-->
<configuration>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%level","logger":"%logger{36}","thread":"%thread","message":"%msg"}%n</pattern>
    </encoder>
  </appender>

  <!-- Уровень логирования для нашего кода -->
  <logger name="com.wayrecall.tracker.websocket" level="INFO" />

  <!-- Подавить шумные логи Kafka -->
  <logger name="org.apache.kafka" level="WARN" />
  <logger name="org.apache.kafka.clients.consumer" level="WARN" />
  <logger name="org.apache.kafka.clients.producer" level="WARN" />

  <!-- ZIO -->
  <logger name="zio" level="INFO" />

  <!-- Netty (HTTP/WS сервер) -->
  <logger name="io.netty" level="WARN" />

  <!-- Для production используй JSON appender, для dev — CONSOLE -->
  <root level="INFO">
    <appender-ref ref="${LOG_FORMAT:-CONSOLE}" />
  </root>

</configuration>
